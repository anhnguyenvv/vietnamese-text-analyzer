{
  "id": null,
  "uid": "vta-http-errors",
  "title": "VTA HTTP & Errors",
  "tags": ["vta", "http", "errors"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests by Status (req/s)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(vta_http_requests_total[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "timeseries",
      "title": "4xx + 5xx Request Rate",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(vta_http_requests_total{status_code=~\"4..|5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 3 }, "overrides": [] },
      "options": { "legend": { "displayMode": "hidden", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "table",
      "title": "Top Endpoints by Throughput",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (rate(vta_http_requests_total[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        }
      ]
    },
    {
      "type": "table",
      "title": "Top Endpoints by Avg Latency (s)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (rate(vta_http_request_duration_seconds_sum[5m])) / sum by (endpoint) (rate(vta_http_request_duration_seconds_count[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference Error vs Success Rate",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vta_inference_error_rate",
          "legendFormat": "error_rate",
          "refId": "A"
        },
        {
          "expr": "vta_inference_success_rate",
          "legendFormat": "success_rate",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "barchart",
      "title": "Inference Errors by Task",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "vta_inference_errors_by_task",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 }, "overrides": [] },
      "options": { "xTickLabelRotation": 0, "xTickLabelSpacing": 100 }
    }
  ]
}
